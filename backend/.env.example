# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL="http://localhost:5000/auth/google/callback"
SESSION_SECRET=
JWT_SECRET=
FRONTEND_ORIGIN="http://localhost:5173"
COOKIE_NAME="ai-memory_vault_session"
COOKIE_MAX_AGE="604800000"
NODE_ENV="development"
PORT="5000"
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
S3_BUCKET=        



# ---------- Worker / queue / embeddings / pinecone ----------
REDIS_URL="redis://127.0.0.1:6379"

# Hugging Face Inference API for embeddings
HF_API_KEY=                 
HF_EMBEDDING_MODEL=

# Pinecone (make sure index dimension matches your HF model)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=     
PINECONE_INDEX=    

# Worker concurrency (how many files to process in parallel)
WORKER_CONCURRENCY="1"

# Chunking defaults for text ingestion
CHUNK_SIZE_TOKENS="700"
CHUNK_OVERLAP_TOKENS="100"

# Query relevance guards (prevent unrelated answers)
QUERY_MIN_MATCH_SCORE="0.35"
QUERY_MIN_TOP_SCORE="0.45"
QUERY_REQUIRE_TERM_OVERLAP="true"

# LLM synthesis for /query/ask
LLM_SYNTHESIS_ENABLED="true"
HF_LLM_MODEL="google/flan-t5-large"
HF_LLM_MODELS="mistralai/Mistral-7B-Instruct-v0.3,Qwen/Qwen2.5-7B-Instruct,google/flan-t5-large"
LLM_MAX_MODELS_TO_TRY="2"
LLM_REQUEST_TIMEOUT_MS="10000"
HF_FALLBACK_ENDPOINTS_ENABLED="true"
LLM_MAX_TOKENS="320"
LLM_TEMPERATURE="0.1"

# Ask query latency controls
QUERY_GRAPH_ON_ASK_DEFAULT="false"

# Knowledge graph (Neo4j) - Phase 2
GRAPH_ENABLED="true"
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
GRAPH_LLM_EXTRACTION_ENABLED="true"
GRAPH_LLM_MAX_TOKENS="220"
